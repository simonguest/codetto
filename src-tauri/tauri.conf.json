{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "jupyter-k12",
  "version": "0.1.0",
  "identifier": "com.simonguest.jupyter-k12",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:55000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Jupyter K-12",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "minHeight": 600,
        "minWidth": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
