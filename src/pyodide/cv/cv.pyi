class Canvas:
    def draw_bounding_boxes(self, detections: list) -> None: ...

class Camera:
    def stop(self) -> None: ...

class Detector:
    def get_detections(self) -> list: ...
    def stop(self) -> None: ...

def get_canvas(width: int = 0, height: int = 0) -> Canvas: ...
def start_camera(canvas: Canvas) -> Camera: ...
def start_face_detector(camera: Camera) -> Detector: ...
def start_object_detector(camera: Camera, delegate: str = "CPU") -> Detector: ...
