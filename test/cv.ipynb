   "source": [
    "import graphics\n",
    "\n",
    "canvas = graphics.canvas(400, 250)\n",
    "ctx = canvas.get_context('2d')\n",
    "\n",
    "ctx.fill_style = '#ff0000'\n",
    "ctx.begin_path()\n",
    "ctx.arc(200, 150, 40, 0, 6.2832)\n",
    "ctx.fill()\n",
    "\n",
    "ctx.fill_style = '#000000'\n",
    "ctx.font = '20px sans-serif'\n",
    "ctx.fill_text('Hello via.js', 130, 60)"
   ]
  }
 ]
