    "# Interrupt Test\n",
    "\n",
    "Tests that a long-running `time.sleep` loop can be interrupted."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-code-1",
   "metadata": {},
   "outputs": [],
   "source": [
    "import time\n",
    "\n",
    "for i in range(1, 11):\n",
    "    print(i)\n",
    "    time.sleep(1)\n",
    "\n",
    "print(\"done\")"
   ]
  }
